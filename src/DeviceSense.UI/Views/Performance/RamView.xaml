<UserControl x:Class="DeviceSense.UI.Views.Performance.RamView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,32">
            <TextBlock Text="RAM" FontSize="24" FontWeight="Bold" Foreground="#1E1E2E" Margin="0,0,0,4"/>
            <TextBlock Text="Memory usage" FontSize="13" Foreground="#9E9EBB" Margin="0,0,0,24"/>
            <Border Background="White" CornerRadius="12" Padding="22" Margin="0,0,0,12">
                <StackPanel>
                    <TextBlock Text="Usage" FontSize="12" Foreground="#6B6B8A" Margin="0,0,0,10"/>
                    <TextBlock FontSize="36" FontWeight="Bold" Foreground="#1E1E2E">
                        <Run Text="{Binding UsagePercent, StringFormat={}{0:F0}}"/><Run Text="%"/>
                    </TextBlock>
                    <ProgressBar Value="{Binding UsagePercent}" Maximum="100"
                                 Height="6" Margin="0,12,0,0" Background="#EDEDF5" Foreground="#22C55E"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
