<UserControl x:Class="DeviceSense.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="#F0F2F5">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,32">

            <TextBlock Text="Dashboard" FontSize="24" FontWeight="Bold"
                       Foreground="#1E1E2E" Margin="0,0,0,8"/>
            <TextBlock Text="System overview at a glance" FontSize="13"
                       Foreground="#9E9EBB" Margin="0,0,0,24"/>

            <!-- Top 3 Cards: CPU / RAM / Battery -->
            <UniformGrid Columns="3" Margin="0,0,0,16">

                <!-- CPU -->
                <Border Margin="0,0,10,0" Background="White" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="CPU Usage" FontSize="12" Foreground="#6B6B8A" Margin="0,0,0,10"/>
                        <TextBlock FontSize="34" FontWeight="Bold" Foreground="#1E1E2E">
                            <Run Text="{Binding Cpu.UsagePercent, StringFormat={}{0:F0}}"/><Run Text="%"/>
                        </TextBlock>
                        <TextBlock Text="{Binding Cpu.Name}" FontSize="11" Foreground="#9E9EBB"
                                   Margin="0,6,0,12" TextTrimming="CharacterEllipsis"/>
                        <ProgressBar Value="{Binding Cpu.UsagePercent}" Maximum="100"
                                     Height="5" Background="#EDEDF5" Foreground="#6C63FF"/>
                    </StackPanel>
                </Border>

                <!-- RAM -->
                <Border Margin="5,0,5,0" Background="White" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="RAM Usage" FontSize="12" Foreground="#6B6B8A" Margin="0,0,0,10"/>
                        <TextBlock FontSize="34" FontWeight="Bold" Foreground="#1E1E2E">
                            <Run Text="{Binding Ram.UsagePercent, StringFormat={}{0:F0}}"/><Run Text="%"/>
                        </TextBlock>
                        <TextBlock FontSize="11" Foreground="#9E9EBB" Margin="0,6,0,12">
                            <Run Text="{Binding Ram.UsedBytes, Converter={StaticResource BytesToGbConverter}}"/>
                            <Run Text=" / "/>
                            <Run Text="{Binding Ram.TotalCapacityBytes, Converter={StaticResource BytesToGbConverter}}"/>
                            <Run Text=" GB"/>
                        </TextBlock>
                        <ProgressBar Value="{Binding Ram.UsagePercent}" Maximum="100"
                                     Height="5" Background="#EDEDF5" Foreground="#22C55E"/>
                    </StackPanel>
                </Border>

                <!-- Battery -->
                <Border Margin="10,0,0,0" Background="White" CornerRadius="12" Padding="20">
                    <StackPanel>
                        <TextBlock Text="Battery" FontSize="12" Foreground="#6B6B8A" Margin="0,0,0,10"/>
                        <TextBlock FontSize="34" FontWeight="Bold" Foreground="#1E1E2E">
                            <Run Text="{Binding Battery.ChargePercent}"/><Run Text="%"/>
                        </TextBlock>
                        <TextBlock FontSize="11" Foreground="#9E9EBB" Margin="0,6,0,12"
                                   Text="{Binding Battery.IsCharging,
                                          Converter={StaticResource BoolToChargingTextConverter}}"/>
                        <ProgressBar Value="{Binding Battery.ChargePercent}" Maximum="100"
                                     Height="5" Background="#EDEDF5" Foreground="#F59E0B"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

        </StackPanel>
    </ScrollViewer>
</UserControl>
