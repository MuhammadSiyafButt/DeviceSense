<UserControl x:Class="DeviceSense.UI.Views.Network.BandwidthView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,32">
            <TextBlock Text="Bandwidth" FontSize="24" FontWeight="Bold" Foreground="#1E1E2E" Margin="0,0,0,4"/>
            <TextBlock Text="Network download and upload speeds" FontSize="13" Foreground="#9E9EBB" Margin="0,0,0,24"/>
            <UniformGrid Columns="2">
                <Border Margin="0,0,10,0" Background="White" CornerRadius="12" Padding="22">
                    <StackPanel>
                        <TextBlock Text="Download" FontSize="12" Foreground="#6B6B8A" Margin="0,0,0,10"/>
                        <TextBlock FontSize="34" FontWeight="Bold" Foreground="#1E1E2E">
                            <Run Text="{Binding DownloadMbps, StringFormat={}{0:F1}}"/><Run Text=" Mbps"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <Border Margin="10,0,0,0" Background="White" CornerRadius="12" Padding="22">
                    <StackPanel>
                        <TextBlock Text="Upload" FontSize="12" Foreground="#6B6B8A" Margin="0,0,0,10"/>
                        <TextBlock FontSize="34" FontWeight="Bold" Foreground="#1E1E2E">
                            <Run Text="{Binding UploadMbps, StringFormat={}{0:F1}}"/><Run Text=" Mbps"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
