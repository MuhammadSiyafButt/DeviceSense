<UserControl x:Class="DeviceSense.UI.Views.Network.WifiSignalView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,32">
            <TextBlock Text="Wi-Fi" FontSize="24" FontWeight="Bold" Foreground="#1E1E2E" Margin="0,0,0,4"/>
            <TextBlock Text="Wireless network information" FontSize="13" Foreground="#9E9EBB" Margin="0,0,0,24"/>
            <UniformGrid Columns="2">
                <Border Margin="0,0,10,10" Background="White" CornerRadius="12" Padding="22">
                    <StackPanel>
                        <TextBlock Text="Network Name (SSID)" FontSize="12" Foreground="#6B6B8A" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding Ssid}" FontSize="20" FontWeight="SemiBold" Foreground="#1E1E2E"/>
                    </StackPanel>
                </Border>
                <Border Margin="10,0,0,10" Background="White" CornerRadius="12" Padding="22">
                    <StackPanel>
                        <TextBlock Text="Signal Strength" FontSize="12" Foreground="#6B6B8A" Margin="0,0,0,10"/>
                        <TextBlock FontSize="36" FontWeight="Bold" Foreground="#1E1E2E">
                            <Run Text="{Binding SignalStrength}"/><Run Text="%"/>
                        </TextBlock>
                        <ProgressBar Value="{Binding SignalStrength}" Maximum="100"
                                     Height="6" Margin="0,12,0,0" Background="#EDEDF5" Foreground="#6C63FF"/>
                    </StackPanel>
                </Border>
                <Border Margin="0,0,10,10" Background="White" CornerRadius="12" Padding="22">
                    <StackPanel>
                        <TextBlock Text="IP Address" FontSize="12" Foreground="#6B6B8A" Margin="0,0,0,10"/>
                        <TextBlock Text="{Binding IpAddress}" FontSize="18" FontWeight="SemiBold" Foreground="#1E1E2E"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
