<UserControl x:Class="DeviceSense.UI.Views.Storage.JunkCleanerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F0F2F5">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="32,28,32,32">
            <TextBlock Text="Junk Cleaner" FontSize="24" FontWeight="Bold" Foreground="#1E1E2E" Margin="0,0,0,4"/>
            <TextBlock Text="Find and remove unnecessary files" FontSize="13" Foreground="#9E9EBB" Margin="0,0,0,24"/>
            <Border Background="White" CornerRadius="12" Padding="24" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="{Binding StatusMessage}" FontSize="14" Foreground="#6B6B8A" Margin="0,0,0,20"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Scan" Command="{Binding ScanCommand}"
                                Padding="24,10" Background="#6C63FF" Foreground="White"
                                BorderThickness="0" FontSize="13" FontWeight="SemiBold" Margin="0,0,12,0"/>
                        <Button Content="Clean" Command="{Binding CleanCommand}"
                                Padding="24,10" Background="#EF4444" Foreground="White"
                                BorderThickness="0" FontSize="13" FontWeight="SemiBold"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
