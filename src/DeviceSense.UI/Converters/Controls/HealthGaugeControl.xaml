             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Width="120" Height="120">
        <Ellipse Stroke="#EDEDF5" StrokeThickness="10"/>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="ValueText" Text="0%" FontSize="20"
                       FontWeight="Bold" Foreground="#1E1E2E" HorizontalAlignment="Center"/>
        </StackPanel>
    </Grid>
</UserControl>